# Variables de entorno para Control Banquete
# Copia este archivo como .env y rellena los valores

# Servidor
NODE_ENV=production
PORT=8080

# JWT Secret (cambia por una cadena aleatoria de 32+ caracteres)
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_SEGURO_DE_32_CARACTERES

# Días de prueba gratuita para nuevos registros
TRIAL_DAYS=3

# Credenciales del Ultra Admin (panel /ultraadmin.html)
ULTRA_ADMIN_EMAIL=ultra@tudominio.com
ULTRA_ADMIN_PASSWORD=CAMBIA_ESTA_PASSWORD

# Email de soporte (aparece en documentos legales)
SUPPORT_EMAIL=soporte@tudominio.com
